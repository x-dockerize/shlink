# -------------------------------------------------
# Shlink
# -------------------------------------------------
# https://hub.docker.com/r/shlinkio/shlink
SHLINK_VERSION=4.3.0

# -------------------------------------------------
# Shlink Web Client
# -------------------------------------------------
# https://hub.docker.com/r/shlinkio/shlink-web-client
SHLINK_ADMIN_VERSION=4.2.0

# -------------------------------------------------
# Hostnames
# -------------------------------------------------
# Kısa linklerin servis edileceği domain (herkese açık)
SHLINK_HOSTNAME=links.example.com

# Yönetim panelinin servis edileceği domain (IP kısıtlamalı)
SHLINK_ADMIN_HOSTNAME=shlink.example.com

# -------------------------------------------------
# Genel
# -------------------------------------------------
TIMEZONE=Europe/Istanbul

# -------------------------------------------------
# Veritabanı
# -------------------------------------------------
DB_DRIVER=postgres
DB_HOST=postgres
DB_PORT=5432
DB_NAME=shlink
DB_USER=shlink
DB_PASSWORD=changeme

# -------------------------------------------------
# Redis
# -------------------------------------------------
REDIS_SERVERS=redis://shlink-redis:6379

# -------------------------------------------------
# GeoLite2 (Ülke / Şehir Takibi)
# -------------------------------------------------
# Ücretsiz lisans: https://www.maxmind.com/en/geolite2/signup
# Boş bırakılırsa ülke/şehir verisi kaydedilmez.
GEOLITE_LICENSE_KEY=
